## DB
POSTGRES_DB=$YOUR_DB
POSTGRES_USER=$YOUR_POSTGRES_USER_ID
POSTGRES_PASSWORD=$YOUR_POSTGRES_PASSWORD
# Local app only:
# DATABASE_URL=postgresql://$YOUR_POSTGRES_USER_ID:$YOUR_POSTGRES_PASSWORD@localhost:5432/$YOUR_DB

## DISCORD
DISCORD_BOT_TOKEN=$YOUR_DISCORD_BOT_TOKEN
DISCORD_CLIENT_ID=$YOUR_DISCORD_CLIENT_ID
DISCORD_REGISTER_COMMANDS_ON_BOOT=true

##OPENAI
OPENAI_API_KEY=$YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-5.4-mini

TZ=Asia/Seoul

